        <body>
            <trans-unit id="be_users.tab">
                <source>Accessibility Checker</source>
            </trans-unit>
            <trans-unit id="be_users.tx_a11ybydefault_developer_corner">
                <source>Grant access to developer corner</source>
            </trans-unit>
            <trans-unit id="be_users.tx_a11ybydefault_developer_corner.description">
                <source>Allows this user to see the developer-facing accessibility findings in the Accessibility Checker module, in addition to the editor-facing ones. Administrators and system maintainers always have this access.</source>
            </trans-unit>
            <trans-unit id="be_groups.tab">
                <source>Accessibility Checker</source>
            </trans-unit>
            <trans-unit id="be_groups.tx_a11ybydefault_developer_corner">
                <source>Grant access to developer corner</source>
            </trans-unit>
            <trans-unit id="be_groups.tx_a11ybydefault_developer_corner.description">
                <source>Allows members of this group to see the developer-facing accessibility findings in the Accessibility Checker module, in addition to the editor-facing ones. Administrators and system maintainers always have this access.</source>
            </trans-unit>
        </body>
