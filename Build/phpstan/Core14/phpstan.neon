includes:
    - ../../../.Build/vendor/saschaegerer/phpstan-typo3/extension.neon

parameters:
    tmpDir: ../../../.cache/phpstan
    treatPhpDocTypesAsCertain: false
    level: 8

    paths:
        - ../../../Classes
        - ../../../Core14
        - ../../../Tests

    excludePaths:
        - ../../../.Build/*
