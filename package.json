{
    "name": "@web-vision/a11y-by-default",
    "version": "0.1.0",
    "private": true,
    "description": "Accessibility checker TYPO3 backend module",
    "scripts": {
        "build": "npm run build:vendor && rollup -c rollup.config.mjs",
        "build:watch": "rollup -c rollup.config.mjs --watch",
        "build:vendor": "cp node_modules/axe-core/axe.min.js Resources/Public/JavaScript/Vendor/axe.min.js && cp node_modules/html_codesniffer/build/HTMLCS.min.js Resources/Public/JavaScript/Vendor/HTMLCS.min.js",
        "test": "jest --passWithNoTests"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^28.0.0",
        "@rollup/plugin-node-resolve": "^15.0.0",
        "@rollup/plugin-typescript": "^12.0.0",
        "@types/node": "^22.0.0",
        "rollup": "^4.0.0",
        "typescript": "^5.7.0"
    },
    "dependencies": {
        "axe-core": "^4.10.0",
        "html_codesniffer": "^3.0.0"
    }
}
