{
    "name": "@web-vision/a11y-by-default",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Accessibility checker TYPO3 backend module",
    "scripts": {
        "build": "npm run build:vendor && rollup -c rollup.config.mjs",
        "build:watch": "rollup -c rollup.config.mjs --watch",
        "build:vendor": "cp node_modules/axe-core/axe.min.js Resources/Public/JavaScript/Vendor/axe.min.js && cp node_modules/html_codesniffer/build/HTMLCS.js Resources/Public/JavaScript/Vendor/HTMLCS.min.js",
        "test": "jest --config jest.config.cjs --passWithNoTests",
        "lint:js": "eslint .",
        "lint:js:fix": "eslint . --fix"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-commonjs": "^28.0.0",
        "@rollup/plugin-node-resolve": "^15.0.0",
        "@rollup/plugin-typescript": "^12.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.0.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.7.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "prettier": "^3.9.4",
        "rollup": "^4.0.0",
        "ts-jest": "^29.4.11",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.62.1"
    },
    "dependencies": {
        "axe-core": "^4.10.0",
        "html_codesniffer": "^2.5.1",
        "tslib": "^2.8.1"
    }
}
