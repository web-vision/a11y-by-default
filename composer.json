{
    "name": "web-vision/a11y-by-default",
    "description": "Accessibility checker backend module for TYPO3 using axe-core and HTML CodeSniffer",
    "homepage": "https://github.com/web-vision/a11y-by-default",
    "support": {
        "docs": "https://docs.typo3.org/p/web-vision/a11y-by-default/main/en-us/"
    },
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Markus Hofmann",
            "email": "m.hofmann@web-vision.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "typo3/cms-core": "^13.4 || ^14.3",
        "typo3/cms-backend": "^13.4 || ^14.3",
        "typo3/cms-fluid": "^13.4 || ^14.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "saschaegerer/phpstan-typo3": "^2.0 || ^3.0",
        "typo3/coding-standards": "^0.8",
        "typo3/testing-framework": "^9.5",
        "symfony/translation": "^7.4 || ^8.1"
    },
    "autoload": {
        "psr-4": {
            "WebVision\\A11yByDefault\\": "Classes/",
            "WebVision\\A11yByDefault\\Core13\\": "Core13/",
            "WebVision\\A11yByDefault\\Core14\\": "Core14/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebVision\\A11yByDefault\\Tests\\": "Tests/"
        }
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "scripts": {
        "test:php:unit": "phpunit -c Build/phpunit/UnitTests.xml",
        "test:php:functional": "phpunit -c Build/phpunit/FunctionalTests.xml",
        "analyze:php": "phpstan analyse -c Build/phpstan/Core13/phpstan.neon --no-progress --ansi",
        "cs:fix": "php-cs-fixer fix --config Build/php-cs-fixer/php-cs-rules.php"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "a11y_by_default",
            "web-dir": ".Build/Web",
            "version": "1.0.0",
            "Package": {
                "providesPackages": []
            }
        }
    }
}
